{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "almanac",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "vite",
        "lint": "oxlint resources/js --fix --quiet",
        "lint:check": "oxlint resources/js --quiet",
        "oxfmt": "oxfmt resources/js --write",
